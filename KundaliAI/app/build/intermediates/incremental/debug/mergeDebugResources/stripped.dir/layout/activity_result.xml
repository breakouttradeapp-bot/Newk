<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back_arrow"
            app:navigationIconTint="#FFD700" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- User Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#25FFD700"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#40FFD700"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDob"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#B0BEC5"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvPob"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#90A4AE"
                        android:drawableStart="@drawable/ic_location_small"
                        android:drawablePadding="4dp"
                        android:drawableTint="#90A4AE" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Kundali Basics Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#30FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔮 Kundali Details"
                        android:textSize="16sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <include layout="@layout/item_kundali_detail"
                            android:id="@+id/itemLagna"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1" />

                        <include layout="@layout/item_kundali_detail"
                            android:id="@+id/itemRashi"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1" />

                        <include layout="@layout/item_kundali_detail"
                            android:id="@+id/itemNakshatra"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1" />

                        <include layout="@layout/item_kundali_detail"
                            android:id="@+id/itemLagnaLord"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1" />

                    </GridLayout>

                    <!-- Individual fields -->
                    <TextView android:id="@+id/tvLagna" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                    <TextView android:id="@+id/tvRashi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                    <TextView android:id="@+id/tvNakshatra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                    <TextView android:id="@+id/tvLagnaLord" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                    <TextView android:id="@+id/tvRashiLord" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>

                    <!-- Display table -->
                    <include layout="@layout/layout_kundali_basics_table" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Planet Positions -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#30FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🪐 Planet Positions"
                        android:textSize="16sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvPlanetPositions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#CFD8DC"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#203A0CA3"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#403A0CA3"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤖 AI Prediction Preview"
                        android:textSize="16sp"
                        android:textColor="#7B6CF6"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvAiPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#CFD8DC"
                        android:lineSpacingMultiplier="1.5" />

                    <!-- Blur overlay for teaser effect -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/gradient_fade_to_dark"
                        android:layout_marginTop="-40dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒 Unlock full prediction →"
                        android:textSize="12sp"
                        android:textColor="#7B6CF6"
                        android:textStyle="italic" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lucky Details -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#30FFD700"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎨"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lucky Color"
                            android:textSize="10sp"
                            android:textColor="#90A4AE" />
                        <TextView
                            android:id="@+id/tvLuckyColor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#FFD700"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍀"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lucky Number"
                            android:textSize="10sp"
                            android:textColor="#90A4AE" />
                        <TextView
                            android:id="@+id/tvLuckyNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:textColor="#FFD700"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💎"
                            android:textSize="24sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gemstone"
                            android:textSize="10sp"
                            android:textColor="#90A4AE" />
                        <TextView
                            android:id="@+id/tvGemstone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#FFD700"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Download PDF Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadPdf"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/download_pdf_paid"
                    android:textSize="16sp"
                    android:textColor="#1A1A2E"
                    app:icon="@drawable/ic_lock"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#FFD700" />

                <ProgressBar
                    android:id="@+id/progressPdf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="#1A1A2E" />

            </FrameLayout>

            <!-- Disclaimer -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#10FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvDisclaimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textSize="10sp"
                    android:textColor="#78909C"
                    android:lineSpacingMultiplier="1.4"
                    android:drawableStart="@drawable/ic_info_small"
                    android:drawablePadding="8dp"
                    android:drawableTint="#78909C" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Banner Ad Container (fixed at bottom) -->
    <LinearLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#0D1B2A"
        android:gravity="center" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
