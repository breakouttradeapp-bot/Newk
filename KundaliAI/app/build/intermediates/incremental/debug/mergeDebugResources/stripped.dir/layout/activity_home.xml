<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- FIX: Full class name instead of broken @string/appbar_scrolling_view_behavior -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#30FFD700"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_zodiac_ring"
                        android:contentDescription="@string/app_name" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/welcome_title"
                        android:textSize="22sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/welcome_subtitle"
                        android:textSize="13sp"
                        android:textColor="#B0BEC5"
                        android:gravity="center" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FIX: style attr FIRST on all MaterialButtons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateKundali"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:text="@string/generate_kundali"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                app:cornerRadius="16dp"
                app:backgroundTint="#FFD700" />

            <!-- FIX: OutlinedButton style first, no conflicting backgroundTint -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDailyRashifal"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:text="@string/daily_rashifal"
                android:textSize="16sp"
                android:textColor="#B39DDB"
                app:cornerRadius="16dp"
                app:strokeColor="#3A0CA3"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnlockPremium"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:text="@string/unlock_premium_pdf"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp"
                app:backgroundTint="#7B2FBE" />

            <!-- Features Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#15FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#20FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/what_you_get"
                        android:textSize="15sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="&#x1F52E;  Lagna, Rashi &amp; Nakshatra" android:textColor="#CFD8DC" android:textSize="13sp" android:padding="3dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="&#x1FA90;  All 9 Planet Positions" android:textColor="#CFD8DC" android:textSize="13sp" android:padding="3dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="&#x1F916;  AI-Powered Predictions" android:textColor="#CFD8DC" android:textSize="13sp" android:padding="3dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="&#x1F4BC;  Career, Love, Health &amp; Finance" android:textColor="#CFD8DC" android:textSize="13sp" android:padding="3dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="&#x1F64F;  Vedic Remedies &amp; Gemstones" android:textColor="#CFD8DC" android:textSize="13sp" android:padding="3dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer links -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvPrivacyPolicy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_policy"
                    android:textSize="12sp"
                    android:textColor="#7986CB"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | "
                    android:textColor="#546E7A" />

                <TextView
                    android:id="@+id/tvTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/terms_conditions"
                    android:textSize="12sp"
                    android:textColor="#7986CB"
                    android:padding="8dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
